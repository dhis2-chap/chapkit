FROM ghcr.io/dhis2-chap/{{ BASE_IMAGE }}:latest

# Switch to root so we can write to /app/.venv and install user deps
# declared in pyproject.toml. chapkit-py currently runs as a non-root user
# with a root-owned venv (chapkit-images issue tracked separately); staying
# at root matches chapkit-r / chapkit-r-inla's runtime posture.
USER root

WORKDIR /work
COPY . /work

{% if HAS_RENV %}
# Restore the R library declared in renv.lock at image build time so the
# container starts instantly instead of bootstrapping renv on every run.
# Installs renv first if the base image doesn't ship it; no-op otherwise.
RUN R -q -e "if (!requireNamespace('renv', quietly = TRUE)) install.packages('renv', repos = 'https://cloud.r-project.org'); renv::restore(prompt = FALSE)"
{% endif %}
{% if LANGUAGE == "python" and USER_DEPENDENCIES %}
# Install the project's Python dependencies (merged from the user's
# original pyproject.toml / pyenv.yaml / conda env) into the chapkit
# venv. Listed inline instead of `uv pip install .` because the
# generated project doesn't need to be installable as a package -
# it's a service, not a library - and the user's scripts often use a
# flat layout (multiple top-level .py files) that setuptools can't
# auto-package. Build tools in the base image handle any source-built
# wheels.
RUN uv pip install --python /app/.venv/bin/python {% for dep in USER_DEPENDENCIES %}"{{ dep }}" {% endfor %}

{% endif %}

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl --fail http://localhost:8000/health || exit 1

CMD ["python", "main.py"]
