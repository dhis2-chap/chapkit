[project]
name = "{{ PROJECT_IDENTIFIER }}"
version = "0.1.0"
description = "{{ PROJECT_DESCRIPTION }}"
requires-python = ">=3.13"
dependencies = [
    "chapkit>={{ CHAPKIT_VERSION }}",
{% for dep in USER_DEPENDENCIES %}
    "{{ dep }}",
{% endfor %}
]

[dependency-groups]
dev = [
    "uvicorn[standard]>=0.30.0",
]
