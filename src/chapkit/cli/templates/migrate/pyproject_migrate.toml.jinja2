[project]
name = {{ PROJECT_IDENTIFIER | tojson }}
version = "0.1.0"
description = {{ PROJECT_DESCRIPTION | tojson }}
requires-python = ">=3.13"
dependencies = [
    {{ ("chapkit>=" ~ CHAPKIT_VERSION) | tojson }},
{% for dep in USER_DEPENDENCIES %}
    {{ dep | tojson }},
{% endfor %}
]

[dependency-groups]
dev = [
    "uvicorn[standard]>=0.30.0",
]
