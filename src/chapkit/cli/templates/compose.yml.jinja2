services:
  api:
    build:
      context: .
      dockerfile: Dockerfile
    ports:
      - "8000:8000"
    volumes:
      - ck_{{ PROJECT_SLUG }}_data:/workspace/data
    environment:
      LOG_FORMAT: json
      LOG_LEVEL: INFO
      WORKERS: 1
      # CHAPKIT_TEMP_DIR: /tmp  # Override temp directory for ML workspaces
    restart: unless-stopped
    networks:
      - ck_{{ PROJECT_SLUG }}

networks:
  ck_{{ PROJECT_SLUG }}:
    driver: bridge

volumes:
  ck_{{ PROJECT_SLUG }}_data:
