{% raw %}{{- if .Values.secrets }}
apiVersion: v1
kind: Secret
metadata:
  name: {{ include "chapkit.fullname" . }}
  labels:
    {{- include "chapkit.labels" . | nindent 4 }}
type: Opaque
stringData:
  {{- range $key, $value := .Values.secrets }}
  {{ $key }}: {{ $value | quote }}
  {{- end }}
{{- end }}{% endraw %}
