replicaCount: 1

image:
  repository: {{ PROJECT_SERVICE_ID }}
  pullPolicy: IfNotPresent
  tag: "latest"

imagePullSecrets: []
nameOverride: ""
fullnameOverride: ""

service:
  type: ClusterIP
  port: 8000

ingress:
  enabled: false
  className: ""
  annotations: {}
    # kubernetes.io/ingress.class: nginx
    # cert-manager.io/cluster-issuer: letsencrypt-prod
  hosts:
    - host: {{ PROJECT_SERVICE_ID }}.local
      paths:
        - path: /
          pathType: Prefix
  tls: []
    # - secretName: {{ PROJECT_SERVICE_ID }}-tls
    #   hosts:
    #     - {{ PROJECT_SERVICE_ID }}.local

persistence:
  enabled: true
  storageClass: ""
  accessMode: ReadWriteOnce
  size: 1Gi

resources:
  requests:
    cpu: 250m
    memory: 512Mi
  limits:
    cpu: "2"
    memory: 2Gi

env:
  LOG_FORMAT: json
  LOG_LEVEL: INFO
  WORKERS: "1"
  DATABASE_URL: "sqlite+aiosqlite:///workspace/data/chapkit.db"
  # CHAPKIT_TEMP_DIR: /tmp

secrets: {}
  # SERVICEKIT_REGISTRATION_KEY: "changeme"

startupProbe:
  httpGet:
    path: /health
    port: http
  failureThreshold: 30
  periodSeconds: 5

livenessProbe:
  httpGet:
    path: /health
    port: http
  periodSeconds: 15
  timeoutSeconds: 5
  failureThreshold: 3

readinessProbe:
  httpGet:
    path: /health
    port: http
  periodSeconds: 10
  timeoutSeconds: 5
  failureThreshold: 3
