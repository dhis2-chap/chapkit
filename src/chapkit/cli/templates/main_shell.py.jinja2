"""{{ PROJECT_DESCRIPTION }}."""

import os
from pathlib import Path

from chapkit import BaseConfig
from chapkit.api import AssessedStatus, MLServiceBuilder, MLServiceInfo, ModelMetadata, PeriodType
from chapkit.artifact import ArtifactHierarchy
{% if WITH_VALIDATION %}
from chapkit.data import DataFrame
from chapkit.ml import ShellModelRunner, ValidationDiagnostic
from geojson_pydantic import FeatureCollection
{% else %}
from chapkit.ml import ShellModelRunner
{% endif %}


class {{ PROJECT_SLUG.replace('_', ' ').title().replace(' ', '') }}Config(BaseConfig):
    """Configuration for {{ PROJECT_NAME }}."""

    # Required: number of prediction periods
    prediction_periods: int = 3

    # Add your model-specific parameters here
    # Config fields can be accessed by external scripts via config.yml
    # For example:
    # min_samples: int = 5
    # model_type: str = "linear_regression"


# Create shell-based runner with command templates
# The runner copies the entire project directory to an isolated workspace
# and executes commands with the workspace as the current directory.
# This allows scripts to use relative paths and imports.
#
# Variables will be substituted with actual file paths at runtime:
#   {data_file} - Training data CSV
#   {historic_file} - Historic data CSV
#   {future_file} - Future data CSV
#   {output_file} - Predictions CSV
#   {geo_file} - Optional GeoJSON file (if provided)
#
# Files available in workspace (scripts can access directly):
#   config.yml - YAML config (always available)
#   model.pickle - Model file (create/use as needed)

{% if TEMPLATE == "shell-r" %}
# Training command template (using relative path to script)
train_command = "Rscript scripts/train.R --data {data_file}"

# Prediction command template (using relative path to script)
predict_command = (
    "Rscript scripts/predict.R "
    "--historic {historic_file} "
    "--future {future_file} "
    "--output {output_file}"
)
{% else %}
# Training command template (using relative path to script)
train_command = "python scripts/train_model.py --data {data_file}"

# Prediction command template (using relative path to script)
predict_command = (
    "python scripts/predict_model.py "
    "--historic {historic_file} "
    "--future {future_file} "
    "--output {output_file}"
)
{% endif %}

{% if WITH_VALIDATION %}
# ====================================================================================
# $validate hooks (optional)
# ====================================================================================
# These Python callbacks power POST /api/v1/ml/$validate, which returns
# structured diagnostics for a train or predict payload WITHOUT running the
# shell scripts. The frontend can call $validate first to surface problems
# (e.g. "n_lags exceeds available context") before submitting an expensive
# training run.
#
# Even with a shell-based runner, validation callbacks run in Python — they
# inspect the payload directly and do NOT invoke your scripts. This keeps the
# endpoint fast and avoids workspace setup.
#
# Both callbacks receive the same inputs as the shell scripts would (config,
# dataframes, geo) and return a list of ValidationDiagnostic. Returning [] means
# "no issues found".
#
# ValidationDiagnostic fields:
#   severity: "error" | "warning" | "info"
#       - error:   blocks submission (response has valid=False)
#       - warning: surfaces an issue but does not block
#       - info:    informational only
#   code: stable machine-readable identifier (use snake_case); the frontend
#         branches on this for rendering / i18n / documentation links.
#   message: human-readable fallback — bake specifics into the text.
#   field: optional dotted path to the offending input — e.g. "config.n_lags",
#          "data", "historic", or "artifact_id".
#
# Framework-level checks (config existence, prediction_periods bounds, empty
# data, failed training artifacts) are ALREADY performed by chapkit — you only
# need to add domain checks that chapkit cannot know about.
#
# See docs/guides/ml-workflows.md for the full endpoint reference.


async def on_validate_train(
    config: {{ PROJECT_SLUG.replace('_', ' ').title().replace(' ', '') }}Config,
    data: DataFrame,
    geo: FeatureCollection | None = None,
) -> list[ValidationDiagnostic]:
    """Return domain-specific diagnostics for a train payload.

    Example - require at least N rows of training data:

        diagnostics: list[ValidationDiagnostic] = []
        min_rows = 10
        if len(data) < min_rows:
            diagnostics.append(ValidationDiagnostic.error(
                code="insufficient_training_samples",
                message=f"Got {len(data)} rows, need at least {min_rows}",
                field="data",
            ))
        return diagnostics
    """
    return []


async def on_validate_predict(
    config: {{ PROJECT_SLUG.replace('_', ' ').title().replace(' ', '') }}Config,
    historic: DataFrame,
    future: DataFrame,
    geo: FeatureCollection | None = None,
) -> list[ValidationDiagnostic]:
    """Return domain-specific diagnostics for a predict payload.

    Example - require historic to cover at least `lookback` periods:

        diagnostics: list[ValidationDiagnostic] = []
        lookback = getattr(config, "lookback", 0)
        if lookback and len(historic) < lookback:
            diagnostics.append(ValidationDiagnostic.error(
                code="insufficient_historic_context",
                message=f"historic has {len(historic)} rows, need {lookback}",
                field="historic",
            ))
        return diagnostics
    """
    return []


{% endif %}
# Create shell model runner
runner: ShellModelRunner[{{ PROJECT_SLUG.replace('_', ' ').title().replace(' ', '') }}Config] = ShellModelRunner(
    train_command=train_command,
    predict_command=predict_command,
{% if WITH_VALIDATION %}
    on_validate_train=on_validate_train,
    on_validate_predict=on_validate_predict,
{% endif %}
)

# Create ML service info with metadata
info = MLServiceInfo(
    id="{{ PROJECT_SERVICE_ID }}",
    display_name="{{ PROJECT_NAME }}",
    version="1.0.0",
    description="Shell-based ML service using external scripts for train/predict. Scripts can be implemented in any language (Python, R, Julia, etc.)",
    model_metadata=ModelMetadata(
        author="Your Name",
        author_assessed_status=AssessedStatus.yellow,
        contact_email="your.email@example.com",
    ),
    period_type=PeriodType.monthly,
    min_prediction_periods=0,
    max_prediction_periods=100,
)

# Create artifact hierarchy for ML artifacts
HIERARCHY = ArtifactHierarchy(
    name="{{ PROJECT_SLUG }}",
    level_labels={0: "ml_training_workspace", 1: "ml_prediction"},
)

# Database configuration
# Uses environment variable or defaults to data/chapkit.db
# Creates data directory if it doesn't exist
DATABASE_URL = os.getenv("DATABASE_URL", "sqlite+aiosqlite:///data/chapkit.db")
if DATABASE_URL.startswith("sqlite") and ":///" in DATABASE_URL:
    db_path = Path(DATABASE_URL.split("///")[1])
    db_path.parent.mkdir(parents=True, exist_ok=True)

# Build the FastAPI application
app = (
    MLServiceBuilder(
        info=info,
        config_schema={{ PROJECT_SLUG.replace('_', ' ').title().replace(' ', '') }}Config,
        hierarchy=HIERARCHY,
        runner=runner,
        database_url=DATABASE_URL,
    )
{% if WITH_MONITORING %}
    .with_monitoring()
{% endif %}
    # See compose.yml for chap-core self-registration env vars.
    .with_registration()
    .build()
)


if __name__ == "__main__":
    from chapkit.api import run_app

    # Default to port 9090 to match the Docker compose host port and avoid the usual
    # busy ports (8000, 8080). Override with the PORT env var. Set reload=True to
    # enable hot reloading during development.
    run_app("main:app", reload=False, port=9090)
