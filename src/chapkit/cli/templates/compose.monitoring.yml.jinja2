services:
  # Service name doubles as the inter-container DNS hostname used by chap-core to
  # reach this service after registration, so it should be unique within the
  # compose stack. Using the project slug avoids collisions when this file is
  # used as a chap-core overlay alongside other model services.
  {{ PROJECT_SLUG }}:
    # Default: build the image locally from this directory.
    build:
      context: .
      dockerfile: Dockerfile
{% if TEMPLATE == "shell-r" %}
    # chapkit-r-inla is amd64-only; runs under Rosetta on Apple Silicon. Drop this if
    # you switch to the chapkit-r base in the Dockerfile.
    platform: linux/amd64
{% endif %}
    # Alternative: pull a prebuilt image from GHCR (comment out `build:` above).
    # image: ghcr.io/<your-org>/{{ PROJECT_SLUG }}:latest
    # pull_policy: always
    # platform: linux/amd64
    ports:
      # Format is "host:container". Default host port is 9090 - avoids the usual busy
      # ports (8000, 8080, 3000). When overlaying onto chap-core alongside other
      # models, pick a unique host port per overlay (chap-core's ewars overlay uses
      # 5002, for example). The container (right) port stays 8000.
      - "9090:8000"
    volumes:
      - ck_{{ PROJECT_SLUG }}_data:/work/data
    environment:
      LOG_FORMAT: json
      LOG_LEVEL: INFO
      WORKERS: 1
      # When integrating with chap-core, register this service on startup:
      # SERVICEKIT_ORCHESTRATOR_URL: http://chap:8000/v2/services/$$register
      # SERVICEKIT_REGISTRATION_KEY: ${SERVICEKIT_REGISTRATION_KEY:-}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "--fail", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    # No `networks:` directive on purpose - see compose.yml comment.
    # When integrating with chap-core, wait for it to be healthy first:
    # depends_on:
    #   chap:
    #     condition: service_healthy

  prometheus:
    image: prom/prometheus:latest
    ports:
      # Host port 9091 because the model service is on 9090. Prometheus still listens
      # on 9090 inside the container - the prometheus.yml scrape target uses that.
      - "9091:9090"
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--web.console.libraries=/usr/share/prometheus/console_libraries"
      - "--web.console.templates=/usr/share/prometheus/consoles"
    volumes:
      - ./monitoring/prometheus:/etc/prometheus:ro
      - ck_{{ PROJECT_SLUG }}_prometheus:/prometheus
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:9090/-/healthy"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    depends_on:
      {{ PROJECT_SLUG }}:
        condition: service_healthy

  grafana:
    image: grafana/grafana:latest
    ports:
      - "3000:3000"
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=admin
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_SERVER_ROOT_URL=http://localhost:3000
      - GF_PATHS_PROVISIONING=/etc/grafana/provisioning
      - GF_INSTALL_PLUGINS=
      - GF_PLUGINS_ALLOW_LOADING_UNSIGNED_PLUGINS=
    volumes:
      - ./monitoring/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./monitoring/grafana/dashboards:/var/lib/grafana/dashboards:ro
      - ck_{{ PROJECT_SLUG }}_grafana:/var/lib/grafana
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:3000/api/health"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    depends_on:
      prometheus:
        condition: service_healthy

volumes:
  ck_{{ PROJECT_SLUG }}_data:
  ck_{{ PROJECT_SLUG }}_prometheus:
  ck_{{ PROJECT_SLUG }}_grafana:
