# {{ PROJECT_NAME }} Dockerfile
FROM ghcr.io/dhis2-chap/chapkit-py:latest

# chapkit-py runs as root; matches chapkit-r / chapkit-r-inla.
USER root

WORKDIR /work
COPY pyproject.toml ./
COPY main.py ./
{% if TEMPLATE == "ml-shell" %}
COPY scripts/ ./scripts/
{% endif %}

# Install user dependencies into the chapkit venv that ships with the base image.
# Reads dependencies from pyproject.toml directly - no build-system or lock file required.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --python /app/.venv/bin/python -r pyproject.toml

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl --fail http://localhost:8000/health || exit 1

# chapkit-py's default CMD is `chapkit run .`, which only works on MLproject directories.
# Init-generated projects ship main.py, so we override here.
CMD ["python", "main.py"]
